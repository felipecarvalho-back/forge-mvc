{
    "name": "felipecarvalho-back/forge-mvc",
    "description": "A simple PHP MVC skeleton for learning and reuse.",
    "type": "project",
    "readme": "README.md",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Core\\": "core/",
            "Scripts\\": "scripts/"
        },
        "files": [
            "core/Support/helpers.php"
        ]
    },
    "authors": [
        {
            "name": "Felipe",
            "email": "felipe2006.co@gmail.com"
        }
    ],
    "keywords": ["php", "mvc", "skeleton", "framework", "router"],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.5.0",
        "vlucas/phpdotenv": "^5.6",
        "firebase/php-jwt": "^7.0",
        "phpmailer/phpmailer": "^7.0",
        "predis/predis": "^3.4",
        "symfony/mercure": "^0.7.2",
        "lcobucci/jwt": "^5.6"
    },
    "scripts": {
        "start": "php -S localhost:8000 -t public",
        "post-create-project-cmd": [
            "Scripts\\Setup::postCreateProject"
        ]
    }
}
